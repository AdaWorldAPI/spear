  "decisions": [
    {
      "id": "D001",
      "topic": "Storage approach",
      "decision": "Columnar (Lance) not KV",
      "rationale": "KV wastes Lance's columnar compression. Proper typed columns enable predicate pushdown.",
      "timestamp": "2026-03-06"
    },
    {
      "id": "D002", 
      "topic": "Query layer",
      "decision": "DataFusion Expr, not SQL strings",
      "rationale": "Type-safe, composable, optimizable, no SQL injection",
      "timestamp": "2026-03-06"
    },
    {
      "id": "D003",
      "topic": "Body storage",
      "decision": "Separate content store (SHA256-addressed)",
      "rationale": "Bodies are large, opaque, read-once. Columnar doesn't help. Dedup via content-addressing.",
      "timestamp": "2026-03-06"
    },
    {
      "id": "D004",
      "topic": "Dependency versions",
      "decision": "LanceDB 0.26, DataFusion 52, Arrow 57",
      "rationale": "Original versions (LanceDB 0.23, DataFusion 49) not published. Updated to latest compatible set. datafusion-functions-array renamed to functions_nested in DF 52. LanceDB create_table now requires RecordBatchReader.",
      "timestamp": "2026-03-06"
    }
  ],
  
  "architecture_invariants": [
    "No SQL strings - DataFusion Expr only",
    "No opaque binary blobs in Lance tables",
    "No JSON anywhere",
    "Column pruning on every query",
    "Predicate pushdown to Lance"
  ],
  
